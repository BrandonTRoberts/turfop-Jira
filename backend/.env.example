PORT=4000
DATABASE_URL=postgresql://postgres:password@localhost:5432/greenkeeper_ops
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_ISSUER=turfops-api
JWT_AUDIENCE=turfops-app
JWT_TTL=12h
APP_BASE_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173
ALLOW_PUBLIC_REGISTRATION=false
ALLOW_MANUAL_TOKEN_PREVIEW=false
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=
# Set ALLOW_MANUAL_TOKEN_PREVIEW=true only as a temporary fallback if SMTP
# delivery is not working and you need reset/invite links returned in API responses.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="TurfOp <no-reply@turfop.com>"
