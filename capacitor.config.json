{
  "appId": "com.turfops.app",
  "appName": "TurfOp",
  "webDir": "dist",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1400,
      "backgroundColor": "#14532d",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  }
}
